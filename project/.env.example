# Supabase Configuration
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_SUPABASE_URL=your-supabase-url

# Stripe Configuration (Use LIVE keys for production)
VITE_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# Site Configuration
VITE_SITE_URL=https://www.tkacvacations.com
SITE_URL=https://yourdomain.com
ADMIN_EMAIL=your_admin_email@example.com

# Note: Server-side secrets (STRIPE_WEBHOOK_SECRET, RESEND_API_KEY, etc.)
# should be configured in Supabase Edge Function secrets, not in .env
